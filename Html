<!DOCTYPE html><html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Page Not Found - Allwrite</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; font-family: Arial, Helvetica, sans-serif; }body {
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #0f172a, #1e293b);
  color: #e2e8f0;
  text-align: center;
  overflow: hidden;
}

/* Floating animation */
@keyframes float {
  0% { transform: translateY(0px); }
  50% { transform: translateY(-10px); }
  100% { transform: translateY(0px); }
}

/* Glitch effect */
@keyframes glitch {
  0% { text-shadow: 2px 2px #38bdf8, -2px -2px #f472b6; }
  20% { text-shadow: -2px 2px #38bdf8, 2px -2px #f472b6; }
  40% { text-shadow: 2px -2px #38bdf8, -2px 2px #f472b6; }
  60% { text-shadow: -2px -2px #38bdf8, 2px 2px #f472b6; }
  80% { text-shadow: 2px 2px #38bdf8, -2px -2px #f472b6; }
  100% { text-shadow: none; }
}

.container {
  max-width: 500px;
  padding: 20px;
  animation: float 4s ease-in-out infinite;
}

.logo {
  font-size: 1.2rem;
  font-weight: bold;
  margin-bottom: 20px;
  color: #38bdf8;
}

h1 {
  font-size: 6rem;
  color: #38bdf8;
  animation: glitch 1s infinite;
}

h2 { margin-top: 10px; font-size: 1.8rem; }

p { margin: 15px 0; color: #94a3b8; }

a {
  display: inline-block;
  margin-top: 20px;
  padding: 12px 20px;
  background: #38bdf8;
  color: #0f172a;
  text-decoration: none;
  border-radius: 8px;
  font-weight: bold;
  transition: 0.3s;
}

a:hover { background: #0ea5e9; }

/* subtle background particles */
.bg::before, .bg::after {
  content: '';
  position: absolute;
  width: 200%;
  height: 200%;
  top: -50%;
  left: -50%;
  background: radial-gradient(circle, rgba(56,189,248,0.08) 1px, transparent 1px);
  background-size: 40px 40px;
  animation: float 10s linear infinite;
}

  </style>
</head>
<body>
  <div class="bg"></div>
  <div class="container">
    <div class="logo">Allwrite</div>
    <h1>404</h1>
    <h2>Oops! Page not found</h2>
    <p>The page you're looking for doesn't exist or was moved.</p>
    <a href="/">Go Back Home</a>
  </div>
</body>
</html>
